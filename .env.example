# Variables de entorno opcionales para el formulario de contacto (src/app/api/contact/route.ts).
# El formulario funciona sin estas variables (solo valida y registra en el log del servidor).
# Para enviar correos reales, descomenta el bloque de Resend en route.ts y define:

# RESEND_API_KEY=
# CONTACT_EMAIL_TO=tu-email@ejemplo.com
