# Variables de entorno para el envío real de correos del formulario de contacto
# (src/app/api/contact/route.ts). Sin estas variables, el formulario sigue
# funcionando igual (valida, aplica rate limiting y honeypot) pero solo
# registra el mensaje en el log del servidor en vez de enviarlo por correo.

# API key de https://resend.com/api-keys (plan gratuito: 3,000 emails/mes)
RESEND_API_KEY=

# Correo donde quieres recibir los mensajes del formulario
CONTACT_EMAIL_TO=

# Opcional: remitente personalizado. Si lo dejas vacío, se usa el dominio de
# pruebas de Resend (onboarding@resend.dev), que funciona sin verificar un
# dominio propio siempre que CONTACT_EMAIL_TO sea tu propio correo verificado.
# RESEND_FROM_EMAIL=Portafolio <onboarding@resend.dev>
